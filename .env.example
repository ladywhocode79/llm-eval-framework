# ── LLM App (the system under test) ──────────────────────────────
# Required: Claude API key for the QA pipeline
ANTHROPIC_API_KEY=your-api-key-here

# ── LLM Judge (the evaluator) ─────────────────────────────────────
# JUDGE_BACKEND controls which model grades the LLM outputs.
#
#   ollama  → local model via Ollama (default, free, no internet needed)
#   openai  → OpenAI via deepeval default (requires OPENAI_API_KEY)
#
JUDGE_BACKEND=ollama

# Ollama model to use as judge (only applies when JUDGE_BACKEND=ollama)
# Pull a model first:  ollama pull llama3.2
# Options (ordered by speed vs quality):
#   llama3.2      — recommended: fast, ~2 GB, good quality
#   llama3.2:1b   — fastest, ~1 GB, lower quality
#   mistral       — higher quality, ~4 GB, slower
#   phi3:mini     — good balance, ~2.3 GB
OLLAMA_MODEL=llama3.2

# Required only when JUDGE_BACKEND=openai
# OPENAI_API_KEY=your-openai-key-here
